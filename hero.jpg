<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>[POST TITLE] — The CC Way</title>
    <meta name="description" content="[POST EXCERPT]">
    <meta property="og:title" content="[POST TITLE]">
    <meta property="og:description" content="[POST EXCERPT]">
    <meta property="og:type" content="article">
    <meta property="og:url" content="https://theccway.com/blog/[POST-SLUG]/">
    
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- Header -->
<header>
    <div class="header-container">
        <div class="logo">
            <img src="logo.png" alt="The CC Way">
        </div>
        <nav>
            <a href="/">Home</a>
            <a href="/blog/">Blog</a>
            <a href="/about/">About</a>
            <a href="/#email-signup" class="nav-cta">Subscribe</a>
        </nav>
        <div class="menu-toggle">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>
</header>

<!-- Blog Post -->
<article class="container py-3">
    <div class="post-header">
        <h1 class="post-title">[POST TITLE]</h1>
        <p class="post-meta">
            Published on <time datetime="[DATE]">[FORMATTED DATE]</time> 
            | 
            [READ TIME] min read
        </p>
    </div>
    
    <div class="post-content">
        <!-- POST CONTENT GOES HERE -->
        
        <p>This is your blog post. Replace this with your actual content.</p>
        
        <p>You can use all standard HTML formatting:</p>
        
        <ul>
            <li>Unordered lists</li>
            <li>Ordered lists</li>
            <li>Links, bold, italic, etc.</li>
        </ul>
        
        <p>The design will handle all the styling automatically.</p>
    </div>
    
    <div class="post-footer">
        <p><strong>— CC</strong></p>
        <p><em>Onward.</em></p>
    </div>
</article>

<!-- Related / Next Steps -->
<section class="container py-3">
    <h2>Keep Reading</h2>
    <div class="blog-list">
        <div class="blog-post-preview">
            <h3><a href="/blog/">Back to Blog</a></h3>
            <p>Check out all articles on leadership, growth, and reinvention.</p>
        </div>
    </div>
</section>

<!-- Email Signup -->
<section id="email-signup" class="email-signup container" style="margin-left: 2rem; margin-right: 2rem; margin-bottom: 3rem;">
    <h3>Get These Articles Delivered</h3>
    <p>New insights on leadership and personal development, straight to your inbox.</p>
    
    <form class="email-signup-form" id="signup-form">
        <input type="email" placeholder="Your email" required>
        <button type="submit">Subscribe</button>
    </form>
</section>

<!-- Footer -->
<footer>
    <div class="container" style="max-width: 1000px; margin: 0 auto; padding: 0 2rem;">
        
        <div class="footer-content">
            <div class="footer-section">
                <h4>The CC Way</h4>
                <p style="font-size: 0.9rem; margin-bottom: 1rem;">Lead Well. Grow Boldly. Reinvent Often.</p>
                <div class="social-links">
                    <a href="https://linkedin.com/in/candidatecoschino" target="_blank" title="LinkedIn">in</a>
                    <a href="https://instagram.com/cccosch" target="_blank" title="Instagram">📷</a>
                </div>
            </div>
            
            <div class="footer-section">
                <h4>Pages</h4>
                <a href="/">Home</a>
                <a href="/blog/">Blog</a>
                <a href="/about/">About</a>
            </div>
            
            <div class="footer-section">
                <h4>Connect</h4>
                <a href="mailto:hello@theccway.com">Email</a>
                <a href="#email-signup">Subscribe</a>
            </div>
        </div>
        
        <div class="footer-bottom">
            <p>&copy; 2026 The CC Way. All rights reserved. Onward.</p>
        </div>
        
    </div>
</footer>

<script src="/js/script.js"></script>

</body>
</html>
